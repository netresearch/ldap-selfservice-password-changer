{
  "name": "@netresearch/ldap-selfservice-password-changer",
  "type": "module",
  "author": "DevMiner <devminer@devminer.xyz>",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "pnpm build:assets && go run .",
    "dev": "pnpm build:assets && (pnpm js:dev & pnpm css:dev & air)",
    "build": "pnpm build:assets && go build",
    "build:assets": "tsc & postcss ./internal/web/tailwind.css -o ./internal/web/static/styles.css & wait",
    "js:build": "tsc",
    "js:dev": "tsc -w --preserveWatchOutput",
    "css:build": "postcss ./internal/web/tailwind.css -o ./internal/web/static/styles.css",
    "css:dev": "pnpm css:build -w",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4 <4.0.4": "4.0.4",
      "yaml@>=2 <2.8.3": "2.8.3",
      "brace-expansion@>=4 <5.0.5": "5.0.5"
    }
  }
}

{
  "name": "@netresearch/ldap-selfservice-password-changer",
  "type": "module",
  "author": "DevMiner <devminer@devminer.xyz>",
  "license": "MIT",
  "scripts": {
    "start": "bun run build:assets && go run .",
    "dev": "bun run build:assets && (bun run js:dev & bun run css:dev & air)",
    "build": "bun run build:assets && go build",
    "build:assets": "tsc & postcss ./internal/web/tailwind.css -o ./internal/web/static/styles.css & wait",
    "js:build": "tsc",
    "js:dev": "tsc -w --preserveWatchOutput",
    "css:build": "postcss ./internal/web/tailwind.css -o ./internal/web/static/styles.css",
    "css:dev": "bun run css:build -w",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "cssnano": "^8.0.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.19",
    "postcss-cli": "^11.0.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.9.5",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.0",
    "typescript-eslint": "^8.63.0"
  },
  "overrides": {
    "brace-expansion": "^5.0.7"
  }
}
